{"rule_id": "quant-impact-market-structure", "theme": "量化影响", "title": "量化影响需要纳入短线市场结构判断", "rule_text": "量化交易会改变短线生态中的资金反馈速度、流动性分布和追涨/抛压结构；分析短线机会时，需要把量化带来的趋同交易、规避策略和盘中反馈纳入市场结构判断。", "when_to_use": ["当作者讨论量化冲击、盘中反馈或短线生态变化时。"], "do_not_use_when": ["只有个股复盘细节、没有市场结构含义时。"], "evidence_claim_ids": ["claim-451671d03a6b0646", "claim-9fa24ae5f750c243", "claim-acaaf4cdb5d413ec", "claim-0f01272d60e70e94", "claim-1bd6f55ea1a4f94f"], "evidence_article_ids": ["25VmrtPmuWI", "1Zn2UmelLMJ", "2ghvnc9bHeR", "2ohHCnLXtP8"], "confidence": "reviewed_v0_2", "caveats": ["不要把量化影响简化成单一利多或利空。"], "source_tags": ["买入触发", "量化影响"], "raw": {"rule_kind": "theme_abstract", "theme": "量化影响", "evidence_count": 5, "bucket": "quant-impact-market-structure"}}
{"rule_id": "quant-impact-not-single-direction", "theme": "量化影响", "title": "不要把量化影响简化为单一利多或利空", "rule_text": "量化影响更像市场结构变量，而不是固定方向结论；同样的量化参与，在不同成交额、指数环境和短线基础行情下会放大不同结果。", "when_to_use": ["当作者用量化解释市场强弱、承接或异动时。"], "do_not_use_when": ["只有情绪表达、没有环境约束或结构含义时。"], "evidence_claim_ids": ["claim-46e97b566ea5469f", "claim-6d4f584afbbfa9a8"], "evidence_article_ids": ["2jbi0efIsof"], "confidence": "reviewed_v0_2", "caveats": ["需要结合指数环境、成交额和短线基础行情共同判断。"], "source_tags": ["量化影响"], "raw": {"rule_kind": "theme_abstract", "theme": "量化影响", "evidence_count": 2, "bucket": "quant-impact-not-single-direction"}}
{"rule_id": "quant-impact-intraday-liquidity", "theme": "量化影响", "title": "量化会影响盘中流动性与反馈节奏", "rule_text": "量化会改变盘中流动性分布和反馈节奏，进而影响追涨、回落、回封和承接的时间结构；短线分析不能只看结果，还要看盘中反馈如何被量化重塑。", "when_to_use": ["当作者讨论盘中承接、追涨抛压、回封或反馈速度时。"], "do_not_use_when": ["只有静态行情判断、没有盘中反馈信息时。"], "evidence_claim_ids": ["claim-ef4706e7c13c1cf0", "claim-07c3a9a457b934fa", "claim-66c0959e9ccbec5f", "claim-080543f469028c23", "claim-08b11dfb69c89a83"], "evidence_article_ids": ["2fQt29pQ3Pa", "2jbi0efIsof", "2ohHCnLXtP8", "1Zn2UmelLMJ", "2bWeZGDSi07"], "confidence": "reviewed_v0_2", "caveats": ["更适合作为结构判断，不直接导出具体买卖指令。"], "source_tags": ["短线基础行情", "量化影响"], "raw": {"rule_kind": "theme_abstract", "theme": "量化影响", "evidence_count": 5, "bucket": "quant-impact-intraday-liquidity"}}
{"rule_id": "turnover-short-term-height", "theme": "成交额 / 量能", "title": "成交额约束短线高度与持续性", "rule_text": "短线高度、接力持续性和赚钱效应受整体成交额与活跃度约束；当成交额不足时，局部强势未必能外推为更高高度或更长持续性。", "when_to_use": ["当作者讨论成交额、接力高度、持续性和赚钱效应时。"], "do_not_use_when": ["只有单只个股强弱、没有整体活跃度背景时。"], "evidence_claim_ids": ["claim-7c8abf7d84d3e9e3", "claim-3a4023259a7db272", "claim-8fa801c11064a31d", "claim-1c80c1f2e95cd4d7", "claim-41733260a45f4999"], "evidence_article_ids": ["2ohHCnLXtP8", "21ZIusToJzV", "24O3rehPcWv"], "confidence": "reviewed_v0_2", "caveats": ["成交额是环境变量，不是单独买卖结论。"], "source_tags": ["市场结构", "成交额", "指数环境", "数字化/标准化", "量化影响"], "raw": {"rule_kind": "theme_abstract", "theme": "成交额 / 量能", "evidence_count": 5, "bucket": "turnover-short-term-height"}}
{"rule_id": "turnover-with-index-context", "theme": "成交额 / 量能", "title": "放量和缩量必须结合指数环境与资金稀缺性判断", "rule_text": "放量、缩量本身没有固定方向含义，必须结合指数环境、资金稀缺性和短线基础行情一起判断；同样的量能变化，在不同市场状态下对应的交易难度并不相同。", "when_to_use": ["当作者讨论放量、缩量、活跃度变化和环境切换时。"], "do_not_use_when": ["只有量能描述、没有指数环境或资金背景时。"], "evidence_claim_ids": ["claim-c1c3ea0d9bd5e06a", "claim-69c5debdc8794968", "claim-58420714a6e676ce", "claim-5b51bdf81cc631e4", "claim-5db540e61b9c4ef6"], "evidence_article_ids": ["2jbi0efIsof", "2ohHCnLXtP8", "1VvuASpPpMr", "25VmrtPmuWI"], "confidence": "reviewed_v0_2", "caveats": ["量能变化需要和市场状态配套解读。"], "source_tags": ["买入触发", "卖出条件", "成交额", "指数环境", "短线基础行情", "量化影响"], "raw": {"rule_kind": "theme_abstract", "theme": "成交额 / 量能", "evidence_count": 5, "bucket": "turnover-with-index-context"}}
{"rule_id": "short-term-base-before-local-opportunity", "theme": "短线基础行情", "title": "先判断短线整体环境，再判断局部机会", "rule_text": "短线机会不能只看单只个股局部强弱，必须先判断整体赚钱效应、接力环境、轮动速度和容错空间；局部机会是否成立，取决于短线基础行情是否支持。", "when_to_use": ["当作者讨论连板、首板、接力和短线容错时。"], "do_not_use_when": ["只有个股点评、没有整体短线生态含义时。"], "evidence_claim_ids": ["claim-27d6b8820885dee1", "claim-38184d61ed1ba0ec", "claim-6e6e4c1cd2740054", "claim-c1c3ea0d9bd5e06a", "claim-07c3a9a457b934fa"], "evidence_article_ids": ["2jbi0efIsof", "1Zn2UmelLMJ", "1VvuASpPpMr"], "confidence": "reviewed_v0_2", "caveats": ["局部龙头强势不等于整体短线环境健康。"], "source_tags": ["成交额", "指数环境", "短线基础行情", "量化影响"], "raw": {"rule_kind": "theme_abstract", "theme": "短线基础行情", "evidence_count": 5, "bucket": "short-term-base-before-local-opportunity"}}
{"rule_id": "short-term-base-not-single-stock", "theme": "短线基础行情", "title": "赚钱效应应看短线整体，而不是单个龙头或局部强势", "rule_text": "短线赚钱效应应从整体接力质量、承接分布和亏钱效应扩散看，而不是把单个龙头或局部强势误判为整体环境转好。", "when_to_use": ["当作者讨论龙头、赚钱效应、亏钱效应或局部强势时。"], "do_not_use_when": ["只有局部情绪评价、没有整体短线生态判断时。"], "evidence_claim_ids": ["claim-7ae975def66992ff", "claim-1238b38b8a84fdc2", "claim-6e1ff63c220e4af7", "claim-a7fc27632cd96dbb", "claim-0c5bf6d39d5a91fb"], "evidence_article_ids": ["1VvuASpPpMr", "2jbi0efIsof", "2bWeZGDSi07", "21ZIusToJzV"], "confidence": "reviewed_v0_2", "caveats": ["龙头表现只能作为局部样本，不能替代整体环境判断。"], "source_tags": ["指数环境", "短线基础行情", "赚钱效应", "龙头"], "raw": {"rule_kind": "theme_abstract", "theme": "短线基础行情", "evidence_count": 5, "bucket": "short-term-base-not-single-stock"}}
{"rule_id": "short-term-base-difficulty", "theme": "短线基础行情", "title": "轮动速度、接力容错和指数成交额背景共同决定短线难度", "rule_text": "短线难度由轮动速度、接力容错、指数环境和成交额背景共同决定；环境越差，越不能把局部强势误当成短线全面回暖。", "when_to_use": ["当作者讨论轮动速度、接力难度、承接或环境压制时。"], "do_not_use_when": ["只有单点行情描述、没有环境变量之间的关系时。"], "evidence_claim_ids": ["claim-20690373fb54268c", "claim-c3d92b374e2483d9", "claim-dd1e19772005d0a3", "claim-17a2bdd7c1e40103", "claim-184a79cda8f754c6"], "evidence_article_ids": ["1Vgsye6eK36", "2bWeZGDSi07", "2ohHCnLXtP8", "1VvuASpPpMr", "21mulzOf8Yb"], "confidence": "reviewed_v0_2", "caveats": ["要和指数环境、成交额约束一起阅读。"], "source_tags": ["仓位管理", "指数环境", "短线基础行情"], "raw": {"rule_kind": "theme_abstract", "theme": "短线基础行情", "evidence_count": 5, "bucket": "short-term-base-difficulty"}}
{"rule_id": "index-environment-risk-appetite", "theme": "指数环境", "title": "指数环境影响短线承接与风险偏好", "rule_text": "指数环境会改变短线承接、风险偏好和仓位容忍度；指数震荡、走弱或风险升高时，短线局部强势的可持续性要打折看待。", "when_to_use": ["当作者讨论指数、风险偏好、承接和短线容错时。"], "do_not_use_when": ["只有单日涨跌陈述、没有承接或风险偏好含义时。"], "evidence_claim_ids": ["claim-6e6e4c1cd2740054", "claim-ed117cf1071a1b82", "claim-d3a0ff453c56ac8f", "claim-1238b38b8a84fdc2", "claim-1d43f83ee28113ea"], "evidence_article_ids": ["1VvuASpPpMr", "2jbi0efIsof", "2ohHCnLXtP8"], "confidence": "reviewed_v0_2", "caveats": ["指数环境影响的是容错与承接，不应被机械当成唯一方向信号。"], "source_tags": ["买入触发", "指数环境", "牛熊切换", "短线基础行情", "赚钱效应", "量化影响"], "raw": {"rule_kind": "theme_abstract", "theme": "指数环境", "evidence_count": 5, "bucket": "index-environment-risk-appetite"}}
{"rule_id": "index-environment-lower-certainty", "theme": "指数环境", "title": "指数震荡或下行风险会降低局部题材确定性", "rule_text": "指数震荡或下行风险抬升时，局部题材和个股的确定性会下降；即使存在热点，也要降低对持续性和高度的预期。", "when_to_use": ["当作者讨论热点持续性、局部题材或大盘压制时。"], "do_not_use_when": ["只有个股复盘、没有指数背景约束时。"], "evidence_claim_ids": ["claim-27d6b8820885dee1", "claim-86914b3d88bfe3e5", "claim-c7b6d955b4e77c3e", "claim-200c6551e0bfbb08", "claim-83f5c83ef3a1a1bd"], "evidence_article_ids": ["2jbi0efIsof", "2ohHCnLXtP8", "1VvuASpPpMr", "28ACjvWeEjl"], "confidence": "reviewed_v0_2", "caveats": ["局部题材强势需要放回大盘环境中重新评估。"], "source_tags": ["成交额", "指数环境", "短线基础行情", "量化影响", "题材持续性"], "raw": {"rule_kind": "theme_abstract", "theme": "指数环境", "evidence_count": 5, "bucket": "index-environment-lower-certainty"}}
{"rule_id": "index-environment-layered-judgment", "theme": "指数环境", "title": "指数、板块、个股需要分层判断", "rule_text": "指数、板块和个股是不同层级的判断对象；分析时应先分清环境层、板块层和个股层，再决定哪些结论可以外推。", "when_to_use": ["当作者讨论大盘、板块、个股之间的关系时。"], "do_not_use_when": ["只有情绪化环境判断、没有层级区分时。"], "evidence_claim_ids": ["claim-06d4d878c50bbbfc", "claim-9f801ab88fb50785", "claim-80871be657572a84"], "evidence_article_ids": ["2jbi0efIsof", "2ohHCnLXtP8", "2bWeZGDSi07"], "confidence": "reviewed_v0_2", "caveats": ["不要用单层级强弱替代全部层级判断。"], "source_tags": ["指数环境", "牛熊切换", "量化影响"], "raw": {"rule_kind": "theme_abstract", "theme": "指数环境", "evidence_count": 3, "bucket": "index-environment-layered-judgment"}}
{"rule_id": "risk-control-reduce-exposure", "theme": "风控", "title": "环境不支持进攻时优先收缩风险暴露", "rule_text": "当指数、成交额、短线基础行情或亏钱效应不支持进攻时，应优先收缩风险暴露、减少交易频率或降低仓位；而不是继续套用强环境下的节奏。", "when_to_use": ["当作者讨论弱市、回撤、亏钱效应、减仓或等待时。"], "do_not_use_when": ["只有口号式风控提醒、没有环境依据时。"], "evidence_claim_ids": ["claim-a6d53867639e3666", "claim-623e3b6b923fee7f", "claim-430e333ecc703089", "claim-9732e82b3495d755", "claim-5518c5aa470f3538"], "evidence_article_ids": ["25VmrtPmuWI", "28ACjvWeEjl", "2jbi0efIsof", "1VvuASpPpMr"], "confidence": "reviewed_v0_2", "caveats": ["风控优先于进攻意愿。"], "source_tags": ["仓位管理", "成交额", "短线基础行情", "量化影响", "风控"], "raw": {"rule_kind": "theme_abstract", "theme": "风控", "evidence_count": 5, "bucket": "risk-control-reduce-exposure"}}
{"rule_id": "risk-control-missing-entry-premise", "theme": "风控", "title": "买入前提不成立时应减少交易或等待", "rule_text": "当买入前提、承接条件或流动性条件不成立时，应减少交易、延后出手或直接等待；而不是强行把弱环境里的反弹解释为可持续机会。", "when_to_use": ["当作者讨论买入前提、承接不足、流动性恶化或等待时。"], "do_not_use_when": ["只有模糊的情绪宣泄、没有可识别前提条件时。"], "evidence_claim_ids": ["claim-2d86cadbf15dbc78", "claim-e0eb1c78f60416f2", "claim-2e949ad67d21ade0", "claim-e90160e37a4ac7d1", "claim-8b04518ea5d111a3"], "evidence_article_ids": ["2jbi0efIsof", "1VvuASpPpMr", "21mulzOf8Yb"], "confidence": "reviewed_v0_2", "caveats": ["这是一条执行约束，不是具体买卖建议。"], "source_tags": ["短线基础行情", "风控"], "raw": {"rule_kind": "theme_abstract", "theme": "风控", "evidence_count": 5, "bucket": "risk-control-missing-entry-premise"}}
{"rule_id": "risk-control-weak-market-priority", "theme": "风控", "title": "亏钱效应、流动性不足和弱市环境下风控优先", "rule_text": "当亏钱效应扩散、流动性不足或弱市环境强化时，风控应优先于进攻；短线策略要先处理风险预算，再考虑机会筛选。", "when_to_use": ["当作者讨论弱市、防守、亏钱效应或仓位管理时。"], "do_not_use_when": ["只有个股层面的抱怨、没有环境层的风险判断时。"], "evidence_claim_ids": ["claim-fbb0b89761bddf8b", "claim-41fa00e960878b4d", "claim-fdc0ada0a1053a95", "claim-2d8d8202a083ae91", "claim-d832417a28904324"], "evidence_article_ids": ["2bWeZGDSi07", "2jbi0efIsof", "25VmrtPmuWI", "2ohHCnLXtP8"], "confidence": "reviewed_v0_2", "caveats": ["需要结合指数环境和成交额共同确认。"], "source_tags": ["风控"], "raw": {"rule_kind": "theme_abstract", "theme": "风控", "evidence_count": 5, "bucket": "risk-control-weak-market-priority"}}
{"rule_id": "bull-bear-no-single-rhythm", "theme": "牛熊切换", "title": "牛市、熊市和切换期不能沿用同一套短线节奏", "rule_text": "牛市、熊市和切换期的短线基础行情不同，不能简单沿用同一套短线节奏；进攻强度、容错预期和风险预算都要随环境调整。", "when_to_use": ["当作者讨论牛市、熊市、切换期和短线节奏时。"], "do_not_use_when": ["只有泛泛的牛熊评论、没有策略差异判断时。"], "evidence_claim_ids": ["claim-0d18577396d6de47", "claim-4401e71816e7b264", "claim-24155837184cdad5", "claim-8a89cc9f5b4d6a08", "claim-3b63682df66aabca"], "evidence_article_ids": ["2bWeZGDSi07", "21ZIusToJzV"], "confidence": "reviewed_v0_2", "caveats": ["牛熊切换要和成交额、指数环境、赚钱效应一起看。"], "source_tags": ["市场结构", "情绪周期", "牛熊切换", "短线基础行情"], "raw": {"rule_kind": "theme_abstract", "theme": "牛熊切换", "evidence_count": 5, "bucket": "bull-bear-no-single-rhythm"}}
{"rule_id": "bull-bear-combined-signals", "theme": "牛熊切换", "title": "牛熊判断必须结合成交额、指数环境和赚钱/亏钱效应", "rule_text": "牛熊判断不是单一标签，而是成交额、指数环境、赚钱效应和亏钱效应共同作用的结果；环境切换时，要重新确认哪些变量在主导市场。", "when_to_use": ["当作者讨论市场状态识别、牛熊判断或环境变化时。"], "do_not_use_when": ["只有情绪化牛熊表述、没有变量支撑时。"], "evidence_claim_ids": ["claim-ed117cf1071a1b82", "claim-c96ab1bcbaaaca45", "claim-184d968de1ea8f8b", "claim-5eb3fc02b6c6ddcd", "claim-b532548766fbbf0e"], "evidence_article_ids": ["2jbi0efIsof", "2bWeZGDSi07", "2fQt29pQ3Pa", "28ACjvWeEjl"], "confidence": "reviewed_v0_2", "caveats": ["不要把牛熊判断当作单一、瞬时信号。"], "source_tags": ["买入触发", "指数环境", "牛熊切换"], "raw": {"rule_kind": "theme_abstract", "theme": "牛熊切换", "evidence_count": 5, "bucket": "bull-bear-combined-signals"}}
